// À copier-coller dans Firebase Console > Firestore Database > Règles > Publier.
// Logique : chacun lit/modifie son propre profil ; les formateurs ont accès à tout ;
// la messagerie n'est visible que par les deux personnes concernées ; le contenu
// des modules est lisible par tous mais modifiable seulement par les formateurs.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isFormateur() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'formateur';
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isFormateur();
      // À la création (inscription), on autorise le rôle choisi (stagiaire ou
      // formateur via code d'invitation vérifié côté application).
      allow create: if isSelf(userId);
      // Après création : un formateur peut tout modifier ; un stagiaire ne peut
      // modifier QUE ses informations personnelles, jamais son propre rôle, son
      // groupe ou son statut d'archivage — cela empêche qu'un stagiaire se
      // donne lui-même le rôle formateur en modifiant directement sa fiche.
      allow update: if isFormateur() ||
        (isSelf(userId) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['prenom', 'nom', 'email', 'niveau_linguistique', 'niveau_informatique', 'updated_at']));
      allow delete: if isFormateur() || isSelf(userId);
    }

    match /groups/{groupId} {
      allow read, write: if isSignedIn() && isFormateur();
    }

    match /moduleContent/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isFormateur();
    }

    match /moduleProgress/{progressId} {
      allow read, write: if isSignedIn() &&
        (resource == null || resource.data.user_id == request.auth.uid || isFormateur());
    }

    match /testResults/{resultId} {
      allow read, write: if isSignedIn() &&
        (resource == null || resource.data.user_id == request.auth.uid || isFormateur());
    }

    match /messages/{messageId} {
      allow read, write: if isSignedIn() &&
        (resource == null ||
         resource.data.sender_id == request.auth.uid ||
         resource.data.recipient_id == request.auth.uid);
    }

    match /activityLogs/{logId} {
      allow read, write: if isSignedIn() &&
        (resource == null || resource.data.user_id == request.auth.uid || isFormateur());
    }

    match /bugReports/{reportId} {
      // Tout le monde peut signaler un problème ; seuls les formateurs peuvent
      // lire la liste et changer le statut (résolu / non résolu).
      allow create: if isSignedIn();
      allow read, update, delete: if isFormateur();
    }

    match /siteMeta/{docId} {
      // Petit document partagé (ex: date de dernière relecture du contenu),
      // lisible par tous, modifiable seulement par les formateurs.
      allow read: if isSignedIn();
      allow write: if isFormateur();
    }
  }
}
